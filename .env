GEMINI_API_KEY=your_gemini_api_key_here
# Generate a Personal Access Token (PAT) from your Asana Developer Console.
ASANA_ACCESS_TOKEN=your_asana_personal_access_token_here

# Generate an OAuth 2.0 Access Token from the Zoho API Console.
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_ACCESS_TOKEN=your_zoho_oauth_access_token_here
ZOHO_ORG_ID=your_zoho_organization_id_here

# The OAuth 2.0 Bearer token for your Workday API client.
WORKDAY_ACCESS_TOKEN=your_workday_access_token_here
WORKDAY_TENANT_NAME=your_workday_tenant_name_here
WORKDAY_HOST=host
